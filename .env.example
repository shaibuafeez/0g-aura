# Required: Your 0G wallet private key (with funds for compute fees)
ZG_PRIVATE_KEY=

# Optional: 0G RPC endpoint (default: https://evmrpc.0g.ai)
ZG_RPC_URL=https://evmrpc.0g.ai

# Optional: Auto-discover compute providers (default: true)
ZG_AUTO_DISCOVER_PROVIDER=true

# Optional: Specific provider address (overrides auto-discovery)
# ZG_PROVIDER_ADDRESS=
